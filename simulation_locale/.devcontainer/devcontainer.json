{
    "name": "TurtleBot 4 Simulation (Jazzy)",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--net=host",
        "--ipc=host",
        "-e", "DISPLAY=${env:DISPLAY}",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix:rw"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-iot.vscode-ros",
                "ms-python.python",
                "twxi.uri"
            ]
        }
    },
    "postCreateCommand": "rosdep update && echo 'Environnement prêt !'"
}